<Window x:Class="EqFlex.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EqFlex.App.ViewModels"
        xmlns:views="clr-namespace:EqFlex.App.Views"
        Title="EQ Flex" Icon="Resources/eq-flex.ico" Height="780" Width="1320"
        MinHeight="500" MinWidth="800"
        Background="{StaticResource BgDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DamageViewModel}"><views:DamageView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CharacterViewModel}"><views:CharacterView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogViewModel}"><views:LogView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:TriggersViewModel}"><views:TriggersView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:OverlaysViewModel}"><views:OverlaysView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:TunnelViewModel}"><views:TunnelView/></DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource BgMidBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,12">
                <TextBlock Text="EQ Flex" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <Button Content="Characters" Command="{Binding ShowCharactersCommand}" Margin="8,3" HorizontalAlignment="Stretch"/>
                <Button Content="Damage"     Command="{Binding ShowDamageCommand}"     Margin="8,3" HorizontalAlignment="Stretch"/>
                <Button Content="Log"        Command="{Binding ShowLogCommand}"        Margin="8,3" HorizontalAlignment="Stretch"/>
                <Button Content="Triggers"   Command="{Binding ShowTriggersCommand}"   Margin="8,3" HorizontalAlignment="Stretch"/>
                <Button Content="Overlays"   Command="{Binding ShowOverlaysCommand}"   Margin="8,3" HorizontalAlignment="Stretch"/>
                <Button Content="Tunnel"     Command="{Binding ShowTunnelCommand}"     Margin="8,3" HorizontalAlignment="Stretch"/>
                <Button Content="Settings"   Command="{Binding ShowSettingsCommand}"   Margin="8,3" HorizontalAlignment="Stretch"/>

                <Separator Background="{StaticResource BorderBrush}" Margin="8,10"/>

                <!-- Update available badge -->
                <Button Command="{Binding ShowUpdateDialogCommand}"
                        Margin="8,0,8,6" HorizontalAlignment="Stretch"
                        Padding="8,5"
                        Visibility="{Binding PendingUpdateVersion,
                                     Converter={StaticResource NotNullToVisConverter}}"
                        ToolTip="A new version of EQ Flex is available">
                    <TextBlock>
                        <Run Text="⬆ Update " Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                        <Run Text="{Binding PendingUpdateVersion}" Foreground="{StaticResource AccentBrush}"/>
                    </TextBlock>
                </Button>

                <!-- Active character — click to go to Characters page -->
                <Button Command="{Binding ShowCharactersCommand}"
                        Margin="8,0" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center" Padding="10,7"
                        ToolTip="Click to manage characters">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="CHARACTER" FontSize="9" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextDimBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock TextTrimming="CharacterEllipsis" FontWeight="SemiBold"
                                   TextAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding ActiveProfile.Name}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveProfile}" Value="{x:Null}">
                                            <Setter Property="Text" Value="No character selected"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding ActiveProfile.Server}"
                                   FontSize="11" TextTrimming="CharacterEllipsis"
                                   TextAlignment="Center" HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextDimBrush}"
                                   Margin="0,1,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveProfile.Server}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActiveProfile}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <ContentPresenter Grid.Column="1" Content="{Binding CurrentPage}"/>
    </Grid>
</Window>
