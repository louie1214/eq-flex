<Window x:Class="EqFlex.App.Overlays.TriggerOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        Width="320" Height="300"
        MinWidth="200" MinHeight="80"
        ResizeMode="CanResize"
        PreviewMouseDown="Window_PreviewMouseDown">

    <Border BorderBrush="#40FFFFFF">
        <Border.Background>
            <SolidColorBrush Color="#1A1A2E" Opacity="{Binding BackgroundOpacity}"/>
        </Border.Background>
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ChromeVisible}" Value="False">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="CornerRadius" Value="4"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- header (collapsed when no chrome) -->
                <RowDefinition Height="Auto"/>  <!-- divider -->
                <RowDefinition Height="*"/>     <!-- content -->
                <RowDefinition Height="Auto"/>  <!-- resize grip (collapsed when no chrome) -->
            </Grid.RowDefinitions>

            <!-- Header — hidden when chrome is off -->
            <Grid Grid.Row="0" x:Name="DragArea" Height="26"
                  Visibility="{Binding ChromeVisible, Converter={StaticResource BoolToVisConverter}}"
                  MouseLeftButtonDown="DragArea_MouseLeftButtonDown">
                <Border Background="#22FFFFFF" CornerRadius="5,5,0,0"/>
                <Grid Margin="8,0">
                    <TextBlock Text="Triggers" VerticalAlignment="Center"
                               FontSize="11" FontWeight="SemiBold" Foreground="#FFD4D4D4"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="LockBtn" Text="🔒" FontSize="11" Cursor="Hand"
                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                   MouseLeftButtonDown="Lock_MouseLeftButtonDown">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="✕" FontSize="11" Cursor="Hand" Foreground="#FF888888"
                                   VerticalAlignment="Center"
                                   MouseLeftButtonDown="Close_MouseLeftButtonDown">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#FFFF5555"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Grid>

            <Border Grid.Row="1" Height="1" Background="#28FFFFFF"
                    Visibility="{Binding ChromeVisible, Converter={StaticResource BoolToVisConverter}}"/>

            <!-- Text alerts + timers -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Text alerts -->
                    <ItemsControl ItemsSource="{Binding Alerts}" Margin="6,4,6,2">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}"
                                           Foreground="{Binding TextColor}"
                                           FontSize="{Binding FontSize}"
                                           FontWeight="{Binding IsBold, Converter={StaticResource BoldConverter}}"
                                           TextWrapping="Wrap" Margin="0,1"
                                           TextAlignment="{Binding DataContext.WpfTextAlignment,
                                               RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Timers -->
                    <ItemsControl ItemsSource="{Binding Timers}" Margin="6,4,6,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="{Binding DataContext.TimerRowHeight,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                      Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <!-- Bar fill proportional to remaining time -->
                                        <ColumnDefinition Width="{Binding BarPercent,
                                            Converter={StaticResource PctToStarConverter}}"/>
                                        <ColumnDefinition Width="{Binding BarPercent,
                                            Converter={StaticResource PctToStarConverter},
                                            ConverterParameter=remainder}"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="{Binding BarColor, Converter={StaticResource StringToBrushConverter}}"
                                            CornerRadius="2" Opacity="0.45"/>
                                    <Grid Grid.ColumnSpan="2" Margin="5,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   FontSize="11" Foreground="#FFD4D4D4"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextAlignment="{Binding DataContext.WpfTextAlignment,
                                                       RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TimeDisplay}"
                                                   FontSize="11" Foreground="#FF9CDCFE"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- Resize grip — hidden when chrome is off -->
            <Grid Grid.Row="3" HorizontalAlignment="Right" Width="14" Height="14"
                  Visibility="{Binding ChromeVisible, Converter={StaticResource BoolToVisConverter}}"
                  Cursor="SizeNWSE" Margin="0,0,2,2"
                  MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown">
                <Path Data="M 0,12 L 12,0 L 12,12 Z" Fill="#35FFFFFF"
                      HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
            </Grid>
        </Grid>
    </Border>
</Window>
