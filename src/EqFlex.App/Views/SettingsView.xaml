<UserControl x:Class="EqFlex.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkBrush}">
    <StackPanel Margin="24">
        <TextBlock Text="Settings" FontSize="15" FontWeight="SemiBold"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

        <TextBlock Text="Parsing" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <CheckBox Content="Parse Damage" IsChecked="{Binding ParseDamage}"/>
        <CheckBox Content="Parse Healing" IsChecked="{Binding ParseHealing}"/>
        <CheckBox Content="Parse Casting" IsChecked="{Binding ParseCasting}"/>
        <CheckBox Content="Parse Chat" IsChecked="{Binding ParseChat}"/>
        <CheckBox Content="Trade Mode" IsChecked="{Binding ParseTrade}"/>

        <Button Content="Save Settings" Command="{Binding SaveCommand}"
                HorizontalAlignment="Left" Margin="0,20,0,0"/>

        <Separator Background="{StaticResource BorderBrush}" Margin="0,20,0,16"/>

        <TextBlock Text="Diagnostics" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <Button Content="Open Log Folder" Command="{Binding OpenLogsCommand}"
                HorizontalAlignment="Left"
                ToolTip="%APPDATA%\EqFlex\logs"
                Margin="0,0,0,8"/>
        <Button Content="Clear All User Data…" Command="{Binding ClearUserDataCommand}"
                HorizontalAlignment="Left"
                ToolTip="Deletes all profiles, triggers, overlays, and settings, then restarts the app"/>
    </StackPanel>
</UserControl>
