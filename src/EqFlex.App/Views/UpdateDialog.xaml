<Window x:Class="EqFlex.App.Views.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available" Width="480" Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="VersionHeader"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource AccentBrush}"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1" Background="{StaticResource BgMidBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Padding="12" Margin="0,0,0,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="NotesBlock" TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="Consolas" FontSize="12"/>
            </ScrollViewer>
        </Border>

        <ProgressBar Grid.Row="2" x:Name="DownloadProgress"
                     Height="6" Minimum="0" Maximum="100"
                     Background="{StaticResource BgMidBrush}"
                     Foreground="{StaticResource AccentBrush}"
                     BorderThickness="0"
                     Visibility="Collapsed"
                     Margin="0,0,0,12"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="LaterBtn" Content="Later" Width="80"
                    Margin="0,0,8,0" Click="Later_Click"/>
            <Button x:Name="UpdateBtn" Content="Update Now" Width="100"
                    Click="Update_Click"/>
        </StackPanel>
    </Grid>
</Window>
