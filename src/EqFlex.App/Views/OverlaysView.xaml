<UserControl x:Class="EqFlex.App.Views.OverlaysView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:EqFlex.App.Controls"
             Background="{StaticResource BgDarkBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Overlays" FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

            <!-- ── Trigger Overlays ── -->
            <TextBlock Text="Trigger Overlays" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextDimBrush}"
                       Margin="0,0,0,12"
                       Text="Create named overlay windows. Each window can be independently positioned, sized, and set to any opacity. Trigger actions target a specific overlay by name."/>

            <!-- Add new overlay -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding NewOverlayName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="+ Add Overlay"
                        Command="{Binding AddTriggerOverlayCommand}"/>
            </Grid>

            <!-- Trigger overlay list -->
            <Border Background="{StaticResource BgMidBrush}" CornerRadius="4"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Margin="0,0,0,20">
                <ItemsControl ItemsSource="{Binding TriggerOverlays}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                    Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="{Binding OverlayName}"
                                                       FontWeight="SemiBold" Margin="0,0,12,0"
                                                       VerticalAlignment="Center"/>
                                            <CheckBox Content="Show border &amp; header"
                                                      IsChecked="{Binding ShowChrome}"
                                                      VerticalAlignment="Center" FontSize="11"/>
                                        </StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Bg opacity:"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextDimBrush}"
                                                       FontSize="11"/>
                                            <Slider Grid.Column="1" Minimum="0" Maximum="1"
                                                    Value="{Binding BackgroundOpacity}"
                                                    VerticalAlignment="Center"
                                                    SmallChange="0.05" LargeChange="0.1"
                                                    TickFrequency="0.1"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding BackgroundOpacity, StringFormat=P0}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextDimBrush}"
                                                       FontSize="11" Margin="8,0,0,0"/>
                                        </Grid>
                                        <!-- Text alignment -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Align:" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextDimBrush}"
                                                       FontSize="11" Margin="0,0,8,0"/>
                                            <RadioButton Content="Left" FontSize="11" Margin="0,0,8,0"
                                                         VerticalAlignment="Center"
                                                         IsChecked="{Binding TextAlign,
                                                             Converter={StaticResource EnumToBoolConverter},
                                                             ConverterParameter=Left}"/>
                                            <RadioButton Content="Center" FontSize="11" Margin="0,0,8,0"
                                                         VerticalAlignment="Center"
                                                         IsChecked="{Binding TextAlign,
                                                             Converter={StaticResource EnumToBoolConverter},
                                                             ConverterParameter=Center}"/>
                                            <RadioButton Content="Right" FontSize="11"
                                                         VerticalAlignment="Center"
                                                         IsChecked="{Binding TextAlign,
                                                             Converter={StaticResource EnumToBoolConverter},
                                                             ConverterParameter=Right}"/>
                                        </StackPanel>
                                        <!-- Timer row height -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Timer height:" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextDimBrush}"
                                                       FontSize="11" Margin="0,0,8,0"/>
                                            <TextBox Text="{Binding TimerRowHeight, UpdateSourceTrigger=LostFocus}"
                                                     Width="40" TextAlignment="Right" FontSize="11"
                                                     ToolTip="Height of each timer row in pixels (14–60)"/>
                                            <TextBlock Text=" px" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextDimBrush}" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Center" Margin="12,0,0,0">
                                        <Button Margin="0,0,6,0"
                                                Command="{Binding DataContext.TogglePreviewCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
                                                    <Setter Property="Content" Value="Preview / Move"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPreview}" Value="True">
                                                            <Setter Property="Content" Value="Lock"/>
                                                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="Delete"
                                                Command="{Binding DataContext.DeleteTriggerOverlayCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- ── FCT Overlay ── -->
            <TextBlock Text="Floating Combat Text (FCT)" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

            <Border Background="{StaticResource BgMidBrush}" CornerRadius="4"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Padding="12,10" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextDimBrush}"
                               Margin="0,0,0,10"
                               Text="Animated numbers float over your game window. Colors: melee=white, crit=orange, spell=blue, DoT=purple, heal=green, incoming=red."/>

                    <!-- Enable + move -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox Content="Enable FCT" IsChecked="{Binding FctVm.IsEnabled}"
                                  Margin="0,0,20,0" VerticalAlignment="Center"/>
                        <Button Content="{Binding FctMoveLabel}" Command="{Binding ToggleFctMoveCommand}"/>
                    </StackPanel>

                    <!-- Show types -->
                    <TextBlock Text="Show:" FontSize="11" Foreground="{StaticResource TextDimBrush}"
                               Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <CheckBox Content="Melee" IsChecked="{Binding FctVm.ShowMelee}"
                                  Margin="0,0,16,0" FontSize="11" VerticalAlignment="Center"/>
                        <CheckBox Content="Ability" IsChecked="{Binding FctVm.ShowAbility}"
                                  Margin="0,0,16,0" FontSize="11" VerticalAlignment="Center"/>
                        <CheckBox Content="Spell/Proc" IsChecked="{Binding FctVm.ShowSpell}"
                                  Margin="0,0,16,0" FontSize="11" VerticalAlignment="Center"/>
                        <CheckBox Content="DoT" IsChecked="{Binding FctVm.ShowDot}"
                                  Margin="0,0,16,0" FontSize="11" VerticalAlignment="Center"/>
                        <CheckBox Content="Heal done" IsChecked="{Binding FctVm.ShowHealDone}"
                                  Margin="0,0,16,0" FontSize="11" VerticalAlignment="Center"/>
                        <CheckBox Content="Heal received" IsChecked="{Binding FctVm.ShowHealReceived}"
                                  Margin="0,0,16,0" FontSize="11" VerticalAlignment="Center"/>
                        <CheckBox Content="Pet" IsChecked="{Binding FctVm.ShowPet}"
                                  Margin="0,0,16,0" FontSize="11" VerticalAlignment="Center"/>
                        <CheckBox Content="Incoming damage" IsChecked="{Binding FctVm.ShowIncoming}"
                                  FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Heal received sub-options -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="↳ Heal received:" FontSize="11"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"
                                   Margin="0,0,10,0"/>
                        <CheckBox Content="Show caster name" FontSize="11" VerticalAlignment="Center"
                                  IsChecked="{Binding FctVm.ShowHealReceivedCaster}"/>
                    </StackPanel>

                    <!-- Animation settings — two rows in one Grid so nothing wraps -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Row 0: Font · Crit · Rise · Dur -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Font:"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="11" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding FctVm.BaseFontSize, UpdateSourceTrigger=LostFocus}"
                                 TextAlignment="Right" FontSize="11"
                                 ToolTip="Base font size in points (8–40)"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text=" pt"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="11"/>

                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Crit:"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="11" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="0" Grid.Column="5"
                                 Text="{Binding FctVm.CritScale, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                                 TextAlignment="Right" FontSize="11"
                                 ToolTip="Critical hit font scale multiplier (e.g. 1.4 = 40% larger)"/>
                        <TextBlock Grid.Row="0" Grid.Column="6" Text=" ×"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="11"/>

                        <TextBlock Grid.Row="0" Grid.Column="8" Text="Rise:"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="11" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="0" Grid.Column="9"
                                 Text="{Binding FctVm.FloatDistance, UpdateSourceTrigger=LostFocus}"
                                 TextAlignment="Right" FontSize="11"
                                 ToolTip="Pixels each number rises (40–400)"/>
                        <TextBlock Grid.Row="0" Grid.Column="10" Text=" px"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="11"/>

                        <TextBlock Grid.Row="0" Grid.Column="12" Text="Dur:"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="11" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="0" Grid.Column="13"
                                 Text="{Binding FctVm.FloatDuration, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                                 TextAlignment="Right" FontSize="11"
                                 ToolTip="Animation duration in seconds (0.5–5.0)"/>
                        <TextBlock Grid.Row="0" Grid.Column="14" Text=" s"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="11"/>

                        <!-- Row 2: Lanes -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Lanes:"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="11" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding FctVm.LaneCount, UpdateSourceTrigger=LostFocus}"
                                 TextAlignment="Right" FontSize="11"
                                 ToolTip="Horizontal columns numbers spread across (1–10). More = less overlap."/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="13"
                                   Text=" columns — more lanes = less overlap when lots of damage fires at once"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="11"/>
                    </Grid>

                    <!-- Colors -->
                    <TextBlock Text="Colors:" FontSize="11" Foreground="{StaticResource TextDimBrush}"
                               Margin="0,10,0,4"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <!-- label | normal-swatch | normal-hex | gap | crit-label | crit-swatch | crit-hex -->
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>

                        <!-- Header -->
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Normal" FontSize="10"
                                   HorizontalAlignment="Center" Foreground="{StaticResource TextDimBrush}"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="3" Text="Critical" FontSize="10"
                                   HorizontalAlignment="Center" Foreground="{StaticResource TextDimBrush}"/>

                        <!-- Melee -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Melee" FontSize="11"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"/>
                        <ctrl:ColorPickerButton Grid.Row="2" Grid.Column="1"
                                SelectedHex="{Binding FctVm.MeleeColor, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="2" Grid.Column="2" FontSize="11" TextAlignment="Center"
                                 Text="{Binding FctVm.MeleeColor, UpdateSourceTrigger=LostFocus}"
                                 ToolTip="Melee auto-attack color (#RRGGBB)"/>
                        <ctrl:ColorPickerButton Grid.Row="2" Grid.Column="5"
                                SelectedHex="{Binding FctVm.MeleeCritColor, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="2" Grid.Column="6" FontSize="11" TextAlignment="Center"
                                 Text="{Binding FctVm.MeleeCritColor, UpdateSourceTrigger=LostFocus}"
                                 ToolTip="Melee critical hit color (#RRGGBB)"/>

                        <!-- Ability -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Ability" FontSize="11"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"/>
                        <ctrl:ColorPickerButton Grid.Row="4" Grid.Column="1"
                                SelectedHex="{Binding FctVm.AbilityColor, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="4" Grid.Column="2" FontSize="11" TextAlignment="Center"
                                 Text="{Binding FctVm.AbilityColor, UpdateSourceTrigger=LostFocus}"
                                 ToolTip="Ability hit color (Backstab, Kick, etc.) (#RRGGBB)"/>
                        <ctrl:ColorPickerButton Grid.Row="4" Grid.Column="5"
                                SelectedHex="{Binding FctVm.AbilityCritColor, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="4" Grid.Column="6" FontSize="11" TextAlignment="Center"
                                 Text="{Binding FctVm.AbilityCritColor, UpdateSourceTrigger=LostFocus}"
                                 ToolTip="Ability critical hit color (#RRGGBB)"/>

                        <!-- Spell/Proc -->
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Spell/Proc" FontSize="11"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"/>
                        <ctrl:ColorPickerButton Grid.Row="6" Grid.Column="1"
                                SelectedHex="{Binding FctVm.SpellColor, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="6" Grid.Column="2" FontSize="11" TextAlignment="Center"
                                 Text="{Binding FctVm.SpellColor, UpdateSourceTrigger=LostFocus}"
                                 ToolTip="Spell / proc damage color (#RRGGBB)"/>
                        <ctrl:ColorPickerButton Grid.Row="6" Grid.Column="5"
                                SelectedHex="{Binding FctVm.SpellCritColor, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="6" Grid.Column="6" FontSize="11" TextAlignment="Center"
                                 Text="{Binding FctVm.SpellCritColor, UpdateSourceTrigger=LostFocus}"
                                 ToolTip="Spell / proc critical color (#RRGGBB)"/>

                        <!-- DoT -->
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="DoT" FontSize="11"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"/>
                        <ctrl:ColorPickerButton Grid.Row="8" Grid.Column="1"
                                SelectedHex="{Binding FctVm.DotColor, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="8" Grid.Column="2" FontSize="11" TextAlignment="Center"
                                 Text="{Binding FctVm.DotColor, UpdateSourceTrigger=LostFocus}"
                                 ToolTip="DoT tick color (#RRGGBB)"/>
                        <ctrl:ColorPickerButton Grid.Row="8" Grid.Column="5"
                                SelectedHex="{Binding FctVm.DotCritColor, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="8" Grid.Column="6" FontSize="11" TextAlignment="Center"
                                 Text="{Binding FctVm.DotCritColor, UpdateSourceTrigger=LostFocus}"
                                 ToolTip="DoT critical tick color (#RRGGBB)"/>

                        <!-- Heal received -->
                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Heal received" FontSize="11"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"/>
                        <ctrl:ColorPickerButton Grid.Row="10" Grid.Column="1"
                                SelectedHex="{Binding FctVm.HealReceivedColor, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="10" Grid.Column="2" FontSize="11" TextAlignment="Center"
                                 Text="{Binding FctVm.HealReceivedColor, UpdateSourceTrigger=LostFocus}"
                                 ToolTip="Healing received color (#RRGGBB)"/>
                        <ctrl:ColorPickerButton Grid.Row="10" Grid.Column="5"
                                SelectedHex="{Binding FctVm.HealReceivedCritColor, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="10" Grid.Column="6" FontSize="11" TextAlignment="Center"
                                 Text="{Binding FctVm.HealReceivedCritColor, UpdateSourceTrigger=LostFocus}"
                                 ToolTip="Healing received critical color (#RRGGBB)"/>

                        <!-- Heal done -->
                        <TextBlock Grid.Row="12" Grid.Column="0" Text="Heal done" FontSize="11"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"/>
                        <ctrl:ColorPickerButton Grid.Row="12" Grid.Column="1"
                                SelectedHex="{Binding FctVm.HealDoneColor, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="12" Grid.Column="2" FontSize="11" TextAlignment="Center"
                                 Text="{Binding FctVm.HealDoneColor, UpdateSourceTrigger=LostFocus}"
                                 ToolTip="Healing done color (#RRGGBB)"/>
                        <ctrl:ColorPickerButton Grid.Row="12" Grid.Column="5"
                                SelectedHex="{Binding FctVm.HealDoneCritColor, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="12" Grid.Column="6" FontSize="11" TextAlignment="Center"
                                 Text="{Binding FctVm.HealDoneCritColor, UpdateSourceTrigger=LostFocus}"
                                 ToolTip="Healing done critical color (#RRGGBB)"/>

                        <!-- Pet -->
                        <TextBlock Grid.Row="14" Grid.Column="0" Text="Pet" FontSize="11"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"/>
                        <ctrl:ColorPickerButton Grid.Row="14" Grid.Column="1"
                                SelectedHex="{Binding FctVm.PetColor, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="14" Grid.Column="2" FontSize="11" TextAlignment="Center"
                                 Text="{Binding FctVm.PetColor, UpdateSourceTrigger=LostFocus}"
                                 ToolTip="Pet damage color (#RRGGBB)"/>
                        <ctrl:ColorPickerButton Grid.Row="14" Grid.Column="5"
                                SelectedHex="{Binding FctVm.PetCritColor, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Row="14" Grid.Column="6" FontSize="11" TextAlignment="Center"
                                 Text="{Binding FctVm.PetCritColor, UpdateSourceTrigger=LostFocus}"
                                 ToolTip="Pet critical damage color (#RRGGBB)"/>
                    </Grid>

                    <!-- Incoming -->
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Incoming" FontSize="11"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}"/>
                        <ctrl:ColorPickerButton Grid.Column="1"
                                SelectedHex="{Binding FctVm.IncomingColor, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Column="2" FontSize="11" TextAlignment="Center"
                                 Text="{Binding FctVm.IncomingColor, UpdateSourceTrigger=LostFocus}"
                                 ToolTip="Incoming damage color (#RRGGBB)"/>
                        <ctrl:ColorPickerButton Grid.Column="5"
                                SelectedHex="{Binding FctVm.IncomingCritColor, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Column="6" FontSize="11" TextAlignment="Center"
                                 Text="{Binding FctVm.IncomingCritColor, UpdateSourceTrigger=LostFocus}"
                                 ToolTip="Incoming critical damage color (#RRGGBB)"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── DPS Overlay ── -->
            <TextBlock Text="Damage Meter Overlay" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

            <Border Background="{StaticResource BgMidBrush}" CornerRadius="4"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Padding="12,10" Margin="0,0,0,12">
                <StackPanel>
                    <!-- Show/hide -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Margin="0,0,8,0" Command="{Binding ToggleDpsVisibleCommand}">
                            <Button.Style>
                                <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
                                    <Setter Property="Content" Value="Show Overlay"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DpsOverlay.IsOpen}" Value="True">
                                            <Setter Property="Content" Value="Hide Overlay"/>
                                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{Binding DpsMoveLabel}"
                                Command="{Binding ToggleDpsMoveCommand}"/>
                    </StackPanel>

                    <!-- Auto-show -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" Content="Auto-show with fights"
                                  IsChecked="{Binding DpsOverlay.AutoShow}"
                                  VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    Margin="12,0,0,0"
                                    Visibility="{Binding DpsOverlay.AutoShow,
                                                 Converter={StaticResource BoolToVisConverter}}">
                            <TextBlock Text="Hide after:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding DpsOverlay.AutoHideDelaySec, UpdateSourceTrigger=LostFocus}"
                                     Width="48" TextAlignment="Right"/>
                            <TextBlock Text=" s" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
