<UserControl x:Class="EqFlex.App.Views.TunnelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:EqFlex.App.Controls"
             Background="{StaticResource BgDarkBrush}">
    <UserControl.Resources>
        <!-- Shared column-header style for all three DataGrids -->
        <Style x:Key="ColHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="{StaticResource BgMidBrush}"/>
            <Setter Property="Foreground"   Value="{StaticResource TextDimBrush}"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Padding"      Value="8,4"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <!-- ElementStyle applied to Time/Type/Seller columns — shows RawLine on hover -->
        <Style x:Key="RawLineTooltipCell" TargetType="TextBlock">
            <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="400"/>
            <Setter Property="ToolTip">
                <Setter.Value>
                    <ToolTip Background="#1E1E1E" BorderBrush="#555" BorderThickness="1" Padding="8,6">
                        <TextBlock Text="{Binding RawLine}" FontFamily="Consolas" FontSize="11"
                                   Foreground="#E8E8E8" MaxWidth="600" TextWrapping="Wrap"/>
                    </ToolTip>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TradeRawLineTooltipCell" TargetType="TextBlock">
            <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="400"/>
            <Setter Property="ToolTip">
                <Setter.Value>
                    <ToolTip Background="#1E1E1E" BorderBrush="#555" BorderThickness="1" Padding="8,6">
                        <TextBlock Text="{Binding Source.RawLine}" FontFamily="Consolas" FontSize="11"
                                   Foreground="#E8E8E8" MaxWidth="600" TextWrapping="Wrap"/>
                    </ToolTip>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Shared cell style for all three DataGrids -->
        <Style x:Key="Cell" TargetType="DataGridCell">
            <Setter Property="Padding"                  Value="8,2"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="Foreground"               Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgMidBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,10">
            <TextBlock Text="TLP Tunnel" FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </Border>

        <TabControl Grid.Row="1" BorderThickness="0">

            <!-- ═══════════════════════════════════════════════════════════ Trades -->
            <TabItem Header="Trades">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Filter bar -->
                    <Border Grid.Row="0" Background="{StaticResource BgMidBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <WrapPanel>
                            <Grid Width="240" Margin="0,0,12,0">
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="6,4,28,4" ToolTip="Search by item name or seller"/>
                                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Width="22" Height="22" Margin="0,0,2,0"
                                        Command="{Binding ClearSearchCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{StaticResource TextDimBrush}" FontSize="10"
                                        Visibility="{Binding HasSearchText, Converter={StaticResource BoolToVisConverter}}"/>
                            </Grid>
                            <ComboBox ItemsSource="{Binding TypeFilters}" SelectedItem="{Binding SelectedTypeFilter}"
                                      Width="80" VerticalAlignment="Center" Margin="0,0,16,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding}"/></DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                                <Run Text="trades"/>
                            </TextBlock>
                        </WrapPanel>
                    </Border>

                    <DataGrid x:Name="TradesGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding FilteredTrades}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserSortColumns="True" CanUserReorderColumns="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              SelectionMode="Single"
                              Background="{StaticResource BgDarkBrush}"
                              RowBackground="{StaticResource BgDarkBrush}"
                              AlternatingRowBackground="{StaticResource BgMidBrush}"
                              BorderThickness="0" ColumnHeaderHeight="28" RowHeight="24"
                              ColumnHeaderStyle="{StaticResource ColHeader}"
                              CellStyle="{StaticResource Cell}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time"   Binding="{Binding TimeDisplay}" Width="110"  ElementStyle="{StaticResource TradeRawLineTooltipCell}"/>
                            <DataGridTextColumn Header="Type"   Binding="{Binding TypeDisplay}" Width="50"  ElementStyle="{StaticResource TradeRawLineTooltipCell}"/>
                            <DataGridTextColumn Header="Seller" Binding="{Binding Seller}"      Width="110" ElementStyle="{StaticResource TradeRawLineTooltipCell}"/>
                            <DataGridTemplateColumn Header="Item" Width="*" SortMemberPath="ItemName">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ItemName}" TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   ToolTipService.ShowDuration="30000"
                                                   ToolTipService.InitialShowDelay="600"
                                                   ToolTipService.ToolTipOpening="OnTradeItemTooltipOpening">
                                            <TextBlock.ToolTip>
                                                <ToolTip Background="#1E1E1E" BorderBrush="#555" BorderThickness="1" Padding="8,6">
                                                    <TextBlock Text="Loading…" FontFamily="Consolas" FontSize="11"
                                                               Foreground="#E8E8E8"
                                                               MaxWidth="340" TextWrapping="Wrap"/>
                                                </ToolTip>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Price"  Binding="{Binding Price}"       Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════ Krono -->
            <TabItem Header="Krono">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- API price card -->
                    <Border Grid.Row="0" Background="{StaticResource BgMidBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="tlp-auctions.com average" FontSize="11"
                                           Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding KronoApiPrice}" FontSize="22" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="{Binding KronoApiInfo}" FontSize="11"
                                           Foreground="{StaticResource TextDimBrush}" Margin="0,3,0,0"
                                           Visibility="{Binding HasKronoApiInfo, Converter={StaticResource BoolToVisConverter}}"/>
                                <TextBlock Text="{Binding KronoError}" FontSize="11" Foreground="#FF6060"
                                           Margin="0,3,0,0"
                                           Visibility="{Binding HasKronoError, Converter={StaticResource BoolToVisConverter}}"/>
                                <TextBlock Text="Refreshing..." FontSize="11"
                                           Foreground="{StaticResource TextDimBrush}" Margin="0,3,0,0"
                                           Visibility="{Binding IsLoadingKrono, Converter={StaticResource BoolToVisConverter}}"/>
                            </StackPanel>

                            <Button Grid.Column="1" Content="↻ Refresh" VerticalAlignment="Center"
                                    Padding="10,5" Command="{Binding RefreshKronoCommand}"
                                    IsEnabled="{Binding IsLoadingKrono, Converter={StaticResource InverseBoolConverter}}"/>
                        </Grid>
                    </Border>

                    <!-- Local sightings label -->
                    <Border Grid.Row="1" Background="{StaticResource BgMidBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="16,5">
                        <TextBlock Text="Local sightings (14 days)" FontSize="11"
                                   FontWeight="SemiBold" Foreground="{StaticResource TextDimBrush}"/>
                    </Border>

                    <!-- Local Krono history -->
                    <DataGrid x:Name="KronoGrid"
                              Grid.Row="2"
                              ItemsSource="{Binding LocalKronoHistory}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserSortColumns="True" CanUserReorderColumns="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              SelectionMode="Single"
                              Background="{StaticResource BgDarkBrush}"
                              RowBackground="{StaticResource BgDarkBrush}"
                              AlternatingRowBackground="{StaticResource BgMidBrush}"
                              BorderThickness="0" ColumnHeaderHeight="28" RowHeight="24"
                              ColumnHeaderStyle="{StaticResource ColHeader}"
                              CellStyle="{StaticResource Cell}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time"   Binding="{Binding TimeDisplay}" Width="110"  ElementStyle="{StaticResource RawLineTooltipCell}"/>
                            <DataGridTextColumn Header="Type"   Binding="{Binding TypeDisplay}" Width="50"  ElementStyle="{StaticResource RawLineTooltipCell}"/>
                            <DataGridTextColumn Header="Seller" Binding="{Binding Seller}"      Width="110" ElementStyle="{StaticResource RawLineTooltipCell}"/>
                            <DataGridTextColumn Header="Item"   Binding="{Binding ItemName}"    Width="*"/>
                            <DataGridTextColumn Header="Price"  Binding="{Binding Price}"       Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════ Alerts -->
            <TabItem Header="Alerts">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- toolbar -->
                        <RowDefinition Height="Auto"/>  <!-- display settings panel -->
                        <RowDefinition Height="160"/>   <!-- alerts list -->
                        <RowDefinition Height="Auto"/>  <!-- edit form -->
                        <RowDefinition Height="Auto"/>  <!-- hits label -->
                        <RowDefinition Height="*"/>     <!-- hits grid -->
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0" Background="{StaticResource BgMidBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="12,6">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                <Button Content="+ Add Alert" Padding="10,4" Margin="0,0,8,0"
                                        Command="{Binding AddAlertCommand}"/>
                                <Button Content="Delete" Padding="10,4" Margin="0,0,8,0"
                                        Command="{Binding DeleteAlertCommand}"/>
                                <Button Content="⚙ Display &amp; Sound" Padding="10,4"
                                        Command="{Binding ToggleAlertSettingsCommand}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="1 kr ≈" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextDimBrush}"
                                           FontSize="12" Margin="0,0,6,0"/>
                                <TextBox Width="70" Padding="4,3" VerticalContentAlignment="Center"
                                         ToolTip="Krono PP value used for alert price comparisons. Auto-filled when you refresh the Krono tab.">
                                    <TextBox.Text>
                                        <Binding Path="KronoRatePp" StringFormat="N0" UpdateSourceTrigger="LostFocus"/>
                                    </TextBox.Text>
                                </TextBox>
                                <TextBlock Text="pp" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextDimBrush}"
                                           FontSize="12" Margin="4,0,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Shared display &amp; sound settings panel -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BgMidBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="12,10"
                            Visibility="{Binding ShowAlertSettings, Converter={StaticResource BoolToVisConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <!-- Text color -->
                            <TextBlock Text="Color" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                       Margin="0,0,6,0"/>
                            <ctrl:ColorPickerButton SelectedHex="{Binding AlertTextColor, Mode=TwoWay}"
                                                    VerticalAlignment="Center" Margin="0,0,12,0"/>

                            <!-- Font size -->
                            <TextBlock Text="Size" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                       Margin="0,0,6,0"/>
                            <TextBox Width="44" Padding="4,3" VerticalContentAlignment="Center"
                                     Text="{Binding AlertFontSize, UpdateSourceTrigger=LostFocus}"
                                     Margin="0,0,4,0"/>
                            <TextBlock Text="pt" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                       Margin="0,0,12,0"/>

                            <!-- Bold -->
                            <CheckBox Content="Bold" IsChecked="{Binding AlertIsBold}"
                                      VerticalAlignment="Center"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      Margin="0,0,20,0"/>

                            <!-- Separator -->
                            <Rectangle Width="1" Fill="{StaticResource BorderBrush}"
                                       VerticalAlignment="Stretch" Margin="0,0,20,0"/>

                            <!-- Overlay -->
                            <TextBlock Text="Overlay" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                       Margin="0,0,6,0"/>
                            <ComboBox Width="140" Padding="6,3"
                                      ItemsSource="{Binding AvailableOverlays}"
                                      SelectedValuePath="OverlayId"
                                      SelectedValue="{Binding AlertOverlayId}"
                                      ScrollViewer.CanContentScroll="False"
                                      Margin="0,0,20,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding OverlayName}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- Sound -->
                            <TextBlock Text="Sound" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                       Margin="0,0,6,0"/>
                            <ComboBox Width="180" Padding="6,3"
                                      ItemsSource="{Binding AvailableSounds}"
                                      SelectedValuePath="FileName"
                                      SelectedValue="{Binding AlertSoundPath}"
                                      ScrollViewer.CanContentScroll="False"
                                      Margin="0,0,6,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Content="Import…" Padding="8,3" Margin="0,0,4,0"
                                    ToolTip="Add a custom audio file to the library"
                                    Command="{Binding ImportSoundCommand}"/>
                            <Button Content="▶" Padding="8,3" ToolTip="Preview sound"
                                    Command="{Binding PreviewAudioCommand}"/>
                        </StackPanel>
                    </Border>

                    <!-- Alerts list -->
                    <DataGrid x:Name="AlertsGrid"
                              Grid.Row="2"
                              ItemsSource="{Binding Alerts}"
                              SelectedItem="{Binding SelectedAlert}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserSortColumns="False" CanUserReorderColumns="False"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              SelectionMode="Single"
                              VirtualizingPanel.IsVirtualizing="False"
                              Background="{StaticResource BgDarkBrush}"
                              RowBackground="{StaticResource BgDarkBrush}"
                              AlternatingRowBackground="{StaticResource BgMidBrush}"
                              BorderThickness="0" ColumnHeaderHeight="28" RowHeight="24"
                              ColumnHeaderStyle="{StaticResource ColHeader}"
                              CellStyle="{StaticResource Cell}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Enabled" Width="60" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Command="{Binding DataContext.SaveAlertEnabledCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn IsReadOnly="True" Header="Keyword"   Binding="{Binding ItemName}"        Width="*"/>
                            <DataGridTextColumn IsReadOnly="True" Header="Type"      Binding="{Binding AlertType}"       Width="50"/>
                            <DataGridTextColumn IsReadOnly="True" Header="Max Price" Binding="{Binding MaxPriceDisplay}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Edit form -->
                    <Border Grid.Row="3"
                            Background="{StaticResource BgMidBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,1"
                            Padding="12,10"
                            Visibility="{Binding HasSelectedAlert, Converter={StaticResource BoolToVisConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 0: Keyword / Type / Max Price -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Keyword"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox   Grid.Row="0" Grid.Column="1"
                                       Text="{Binding EditItemName, UpdateSourceTrigger=PropertyChanged}"
                                       Padding="6,3"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Type"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                       VerticalAlignment="Center" Margin="12,0,8,0"/>
                            <ComboBox  Grid.Row="0" Grid.Column="3"
                                       ItemsSource="{Binding AlertTypeOptions}"
                                       SelectedItem="{Binding EditAlertType}"
                                       Padding="6,3"/>

                            <TextBlock Grid.Row="0" Grid.Column="4" Text="Max Price"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                       VerticalAlignment="Center" Margin="12,0,8,0"/>
                            <TextBox   Grid.Row="0" Grid.Column="5"
                                       Text="{Binding EditMaxPrice, UpdateSourceTrigger=PropertyChanged}"
                                       Padding="6,3"
                                       ToolTip="Blank = no limit. Examples: 5000  ·  10k  ·  1kr  ·  1kr 5k"/>

                            <!-- Row 2: Enabled + Save -->
                            <CheckBox  Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                       Content="Enabled" IsChecked="{Binding EditIsEnabled}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Button    Grid.Row="2" Grid.Column="6"
                                       Content="Save" Padding="16,4"
                                       Command="{Binding SaveAlertCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Hits label -->
                    <Border Grid.Row="4" Background="{StaticResource BgMidBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="16,5">
                        <TextBlock Text="Recent hits (14 days)" FontSize="11"
                                   FontWeight="SemiBold" Foreground="{StaticResource TextDimBrush}"/>
                    </Border>

                    <!-- Hits grid -->
                    <DataGrid x:Name="AlertHitsGrid"
                              Grid.Row="5"
                              ItemsSource="{Binding AlertHits}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserSortColumns="True" CanUserReorderColumns="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              SelectionMode="Single"
                              Background="{StaticResource BgDarkBrush}"
                              RowBackground="{StaticResource BgDarkBrush}"
                              AlternatingRowBackground="{StaticResource BgMidBrush}"
                              BorderThickness="0" ColumnHeaderHeight="28" RowHeight="24"
                              ColumnHeaderStyle="{StaticResource ColHeader}"
                              CellStyle="{StaticResource Cell}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time"   Binding="{Binding TimeDisplay}" Width="110"  ElementStyle="{StaticResource RawLineTooltipCell}"/>
                            <DataGridTextColumn Header="Item"   Binding="{Binding ItemName}"    Width="*"/>
                            <DataGridTextColumn Header="Seller" Binding="{Binding Seller}"      Width="110" ElementStyle="{StaticResource RawLineTooltipCell}"/>
                            <DataGridTextColumn Header="Price"  Binding="{Binding Price}"       Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════ Prices -->
            <TabItem Header="Prices">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search bar -->
                    <Border Grid.Row="0" Background="{StaticResource BgMidBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Search" Padding="14,4"
                                    Command="{Binding SearchPricesCommand}"
                                    IsEnabled="{Binding IsSearchingPrices, Converter={StaticResource InverseBoolConverter}}"/>
                            <CheckBox DockPanel.Dock="Right"
                                      Content="Include API" VerticalAlignment="Center"
                                      IsChecked="{Binding IncludeApiResults}"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      Margin="0,0,12,0"
                                      ToolTip="Always fetch from tlp-auctions.com, even when local data exists"/>
                            <TextBox Text="{Binding PriceSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,8,0" Padding="6,4"
                                     ToolTip="Search by item name — uses local data first, falls back to tlp-auctions.com">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SearchPricesCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </DockPanel>
                    </Border>

                    <!-- Status / API summary -->
                    <Border Grid.Row="1" Background="{StaticResource BgMidBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="16,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding PriceStatusText}" FontSize="11"
                                       Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="  ·  " FontSize="11"
                                       Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"
                                       Visibility="{Binding HasApiPriceSummary, Converter={StaticResource BoolToVisConverter}}"/>
                            <TextBlock Text="{Binding ApiPriceSummary}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                                       Visibility="{Binding HasApiPriceSummary, Converter={StaticResource BoolToVisConverter}}"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="PricesGrid"
                              Grid.Row="2"
                              ItemsSource="{Binding PriceResults}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserSortColumns="True" CanUserReorderColumns="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              SelectionMode="Single"
                              Background="{StaticResource BgDarkBrush}"
                              RowBackground="{StaticResource BgDarkBrush}"
                              AlternatingRowBackground="{StaticResource BgMidBrush}"
                              BorderThickness="0" ColumnHeaderHeight="28" RowHeight="24"
                              ColumnHeaderStyle="{StaticResource ColHeader}"
                              CellStyle="{StaticResource Cell}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time"   Binding="{Binding TimeDisplay}" Width="110"/>
                            <DataGridTextColumn Header="Type"   Binding="{Binding TypeDisplay}" Width="50"/>
                            <DataGridTemplateColumn Header="Item" Width="*" SortMemberPath="ItemName">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ItemName}" TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   ToolTipService.ShowDuration="30000"
                                                   ToolTipService.InitialShowDelay="600"
                                                   ToolTipService.ToolTipOpening="OnPriceItemTooltipOpening">
                                            <TextBlock.ToolTip>
                                                <ToolTip Background="#1E1E1E" BorderBrush="#555" BorderThickness="1" Padding="8,6">
                                                    <TextBlock Text="Loading…" FontFamily="Consolas" FontSize="11"
                                                               Foreground="#E8E8E8"
                                                               MaxWidth="340" TextWrapping="Wrap"/>
                                                </ToolTip>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Seller" Binding="{Binding Seller}"      Width="110"/>
                            <DataGridTextColumn Header="Price"  Binding="{Binding Price}"       Width="110"/>
                            <DataGridTextColumn Header="Src"    Binding="{Binding Source}"      Width="45"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
