<Window x:Class="EqFlex.App.Views.ShareTriggerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Share Trigger Folder"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <StackPanel Margin="20">

        <!-- Folder info -->
        <TextBlock Text="Folder:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,3"/>
        <TextBlock FontWeight="SemiBold" FontSize="14" Margin="0,0,0,2">
            <Run Text="{Binding FolderName, Mode=OneWay}"/>
        </TextBlock>
        <TextBlock Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,16">
            <Run Text="{Binding TriggerCount, Mode=OneWay}"/>
            <Run Text=" triggers"/>
        </TextBlock>

        <!-- Author -->
        <TextBlock Text="Author name (optional):" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
        <TextBox Text="{Binding AuthorName, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,16" Padding="6,4"/>

        <!-- Generate button -->
        <Button Content="Generate Share Code"
                Command="{Binding GenerateCodeCommand}"
                IsEnabled="{Binding IsUploading, Converter={StaticResource InverseBoolConverter}}"
                HorizontalAlignment="Left" Padding="10,5" Margin="0,0,0,12"/>

        <!-- Uploading indicator -->
        <TextBlock Text="Uploading…"
                   Foreground="{StaticResource TextDimBrush}" FontSize="11"
                   Visibility="{Binding IsUploading, Converter={StaticResource BoolToVisConverter}}"
                   Margin="0,0,0,8"/>

        <!-- Error -->
        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="#FFFF4444" FontSize="11" TextWrapping="Wrap"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NotNullToVisConverter}}"
                   Margin="0,0,0,8"/>

        <!-- Result area -->
        <Border Visibility="{Binding HasCode, Converter={StaticResource BoolToVisConverter}}"
                Background="{StaticResource BgMidBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="3" Padding="12,10" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Share code — paste into EQ or share with others:"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="CodeBox"
                             Text="{Binding FullCode, Mode=OneWay}"
                             IsReadOnly="True" FontFamily="Consolas" FontSize="13"
                             Padding="6,4" Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="Copy"
                            Command="{Binding CopyCodeCommand}"
                            Padding="10,4"/>
                </Grid>
                <TextBlock Text="Codes expire after 90 days."
                           Foreground="{StaticResource TextDimBrush}" FontSize="10" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Close -->
        <Button Content="Close" Click="Close_Click"
                HorizontalAlignment="Right" Padding="12,5"/>

    </StackPanel>
</Window>
