<UserControl x:Class="EqFlex.App.Views.CharacterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkBrush}">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Profile list -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Characters" FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="New"    Command="{Binding NewProfileCommand}"      Margin="0,0,6,0"/>
                <Button Content="Edit"   Command="{Binding EditProfileCommand}"     Margin="0,0,6,0"/>
                <Button Content="Delete" Command="{Binding DeleteProfileCommand}"   Margin="0,0,6,0"/>
                <Button Content="Set Active" Command="{Binding ActivateProfileCommand}"
                        ToolTip="Use this profile for log parsing and triggers"/>
            </StackPanel>

            <ListBox Grid.Row="2" ItemsSource="{Binding Profiles}"
                     SelectedItem="{Binding SelectedProfile}"
                     Background="{StaticResource BgMidBrush}"
                     BorderBrush="{StaticResource BorderBrush}"
                     Foreground="{StaticResource TextPrimaryBrush}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,2">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                            <TextBlock Foreground="{StaticResource TextDimBrush}" FontSize="11">
                                <Run Text="{Binding PlayerName}"/><Run Text=" — "/><Run Text="{Binding Server}"/>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Read-only detail view -->
        <Border Grid.Column="2" Background="{StaticResource BgMidBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Padding="20"
                Visibility="{Binding ShowDetail, Converter={StaticResource BoolToVisConverter}}">
            <StackPanel>
                <TextBlock Text="{Binding SelectedProfile.Name}" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Character"
                               Foreground="{StaticResource TextDimBrush}" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="{Binding SelectedProfile.PlayerName}"
                               VerticalAlignment="Center" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Server"
                               Foreground="{StaticResource TextDimBrush}" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="{Binding SelectedProfile.Server}"
                               VerticalAlignment="Center" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Log File"
                               Foreground="{StaticResource TextDimBrush}" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="2" Grid.Column="1"
                               Text="{Binding SelectedProfile.LogPath}"
                               VerticalAlignment="Center" Margin="0,0,0,10"
                               TextWrapping="Wrap" FontSize="11"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Log Archiving"
                               Foreground="{StaticResource TextDimBrush}" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="3" Grid.Column="1"
                               VerticalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Disabled"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedProfile.LogArchiveEnabled}" Value="True">
                                        <Setter Property="Text"
                                                Value="{Binding SelectedProfile.LogArchiveSizeMb,
                                                        StringFormat='Enabled (max {0} MB)'}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Parse Combat"
                               Foreground="{StaticResource TextDimBrush}" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="4" Grid.Column="1"
                               VerticalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="No"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedProfile.ParseCombat}" Value="True">
                                        <Setter Property="Text" Value="Yes"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Trade Mode"
                               Foreground="{StaticResource TextDimBrush}" FontSize="11"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="No"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedProfile.ParseTrade}" Value="True">
                                        <Setter Property="Text" Value="Yes"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Edit form -->
        <Border Grid.Column="2" Background="{StaticResource BgMidBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Padding="20"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}}">
            <StackPanel>
                <TextBlock Text="Edit Profile" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

                <TextBlock Text="Display Name"/>
                <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>

                <TextBlock Text="Log File Path"/>
                <Grid Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding EditLogPath, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="1" Content="Browse…" Command="{Binding BrowseLogPathCommand}"
                            Margin="6,0,0,0"/>
                </Grid>
                <TextBlock Text="Located in your EverQuest folder: eqlog_CharacterName_Server.txt"
                           Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,12"
                           TextWrapping="Wrap"/>

                <TextBlock Text="EQ Character Name"/>
                <TextBox Text="{Binding EditPlayerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>

                <TextBlock Text="Server"/>
                <TextBox Text="{Binding EditServer, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>

                <TextBlock Text="Log Archiving" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <CheckBox Content="Archive log when it reaches size limit"
                          IsChecked="{Binding EditLogArchiveEnabled}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,12"
                      Visibility="{Binding EditLogArchiveEnabled, Converter={StaticResource BoolToVisConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Max size:" VerticalAlignment="Center"
                               Foreground="{StaticResource TextDimBrush}" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1" TextAlignment="Right"
                             Text="{Binding EditLogArchiveSizeMb, UpdateSourceTrigger=LostFocus}"/>
                    <TextBlock Grid.Column="2" Text=" MB" VerticalAlignment="Center"
                               Foreground="{StaticResource TextDimBrush}"/>
                </Grid>

                <TextBlock Text="Parsing Options" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <CheckBox Content="Parse Combat" IsChecked="{Binding EditParseCombat}"/>
                <CheckBox Content="Trade Mode" IsChecked="{Binding EditParseTrade}"/>

                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                    <Button Content="Save" Command="{Binding SaveProfileCommand}" Margin="0,0,8,0"/>
                    <Button Content="Cancel" Command="{Binding CancelEditCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Placeholder when nothing selected -->
        <Border Grid.Column="2" Background="{StaticResource BgMidBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4"
                Visibility="{Binding ShowPlaceholder, Converter={StaticResource BoolToVisConverter}}">
            <TextBlock Text="Select a profile or click New to create one."
                       Foreground="{StaticResource TextDimBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
