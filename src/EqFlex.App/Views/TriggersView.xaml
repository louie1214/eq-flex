<UserControl x:Class="EqFlex.App.Views.TriggersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:EqFlex.Core.Models;assembly=EqFlex.Core"
             xmlns:vm="clr-namespace:EqFlex.App.ViewModels"
             xmlns:ctrl="clr-namespace:EqFlex.App.Controls"
             Background="{StaticResource BgDarkBrush}">
    <UserControl.Resources>
        <x:Array x:Key="ActionTypeValues" Type="{x:Type models:TriggerActionType}">
            <models:TriggerActionType>DisplayText</models:TriggerActionType>
            <models:TriggerActionType>Speak</models:TriggerActionType>
            <models:TriggerActionType>PlayAudio</models:TriggerActionType>
            <models:TriggerActionType>Timer</models:TriggerActionType>
            <models:TriggerActionType>ShowFct</models:TriggerActionType>
        </x:Array>

        <!--
            Custom TreeViewItem template for folder nodes.
            Identical to the WPF default except the expander ToggleButton is always visible —
            the default hides it via a HasItems=false trigger, which obscures empty folders.
        -->
        <ControlTemplate x:Key="FolderTreeViewItemTemplate" TargetType="TreeViewItem">
            <StackPanel>
                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <ToggleButton x:Name="Expander" Grid.Column="0" Focusable="False" ClickMode="Press"
                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <TextBlock x:Name="Arrow" Text="▶" FontSize="7"
                                               Foreground="{StaticResource TextDimBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter x:Name="PART_Header" Grid.Column="1"
                                          ContentSource="Header" VerticalAlignment="Center"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                    </Grid>
                </Border>
                <ItemsPresenter x:Name="ItemsHost" Margin="16,0,0,0" Visibility="Collapsed"/>
            </StackPanel>
            <ControlTemplate.Triggers>
                <Trigger Property="IsExpanded" Value="True">
                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="160"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*" MinWidth="320"/>
        </Grid.ColumnDefinitions>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}"
                      ResizeBehavior="PreviousAndNext" Cursor="SizeWE"/>

        <!-- Left: folder/trigger tree -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Background="{StaticResource BgMidBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="6,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Triggers" Foreground="{StaticResource TextSecondaryBrush}"
                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <!-- Normal-mode buttons (hidden in select mode) -->
                    <Button Content="+ Folder" Command="{Binding AddFolderCommand}"
                            Padding="6,3" FontSize="11" Margin="0,0,4,0"
                            Visibility="{Binding IsSelectMode, Converter={StaticResource InverseBoolToVisConverter}}"/>
                    <Button Content="+ Trigger" Command="{Binding AddTriggerCommand}"
                            Padding="6,3" FontSize="11" Margin="0,0,4,0"
                            Visibility="{Binding IsSelectMode, Converter={StaticResource InverseBoolToVisConverter}}"/>
                    <Button Content="Delete" Command="{Binding DeleteSelectedCommand}"
                            Padding="6,3" FontSize="11" Margin="0,0,4,0"
                            Visibility="{Binding IsSelectMode, Converter={StaticResource InverseBoolToVisConverter}}"/>
                    <Button Content="Import NAG…" Padding="6,3" FontSize="11" Margin="0,0,8,0"
                            Click="ImportNag_Click"
                            Visibility="{Binding IsSelectMode, Converter={StaticResource InverseBoolToVisConverter}}"
                            ToolTip="Import triggers from a NAG trigger-database.json file"/>
                    <!-- Select-mode toggle (always visible) -->
                    <Button Content="☑ Select" Click="ToggleSelectMode_Click"
                            Padding="6,3" FontSize="11" Margin="0,0,4,0">
                        <Button.Style>
                            <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelectMode}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <!-- Delete Marked (select mode only) -->
                    <Button Content="Delete Marked" Click="DeleteMarked_Click"
                            Padding="6,3" FontSize="11"
                            Visibility="{Binding IsSelectMode, Converter={StaticResource BoolToVisConverter}}"/>
                </StackPanel>
            </Border>

            <!-- Loading indicator -->
            <Border Grid.Row="1"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}}"
                    Background="{StaticResource BgMidBrush}">
                <TextBlock Text="Loading triggers…" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{StaticResource TextDimBrush}" FontSize="12"/>
            </Border>

            <!-- Tree -->
            <TreeView Grid.Row="1" x:Name="TriggerTree"
                      ItemsSource="{Binding FolderNodes}"
                      SelectedItemChanged="TriggerTree_SelectedItemChanged"
                      Background="{StaticResource BgMidBrush}" BorderThickness="0"
                      Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisConverter}}"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True">

                <!-- Folder item container: bind IsExpanded to node -->
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay, FallbackValue=True}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        <Setter Property="Padding" Value="3,3"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template" Value="{StaticResource FolderTreeViewItemTemplate}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.ItemContainerStyle>

                <TreeView.Resources>
                    <!-- Folder template — Children contains sub-folders then trigger nodes -->
                    <HierarchicalDataTemplate DataType="{x:Type vm:TriggerFolderNode}"
                                              ItemsSource="{Binding Children}">
                        <HierarchicalDataTemplate.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay, FallbackValue=True}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="Padding" Value="3,2"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource BgLightBrush}"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="True"/>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                    </MultiTrigger>
                                    <!-- Sub-folders get the always-visible expander; trigger nodes use the default -->
                                    <DataTrigger Binding="{Binding IsFolder, FallbackValue=False}" Value="True">
                                        <Setter Property="Template" Value="{StaticResource FolderTreeViewItemTemplate}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </HierarchicalDataTemplate.ItemContainerStyle>

                        <StackPanel Orientation="Horizontal">
                            <!-- Mark checkbox (select mode only) -->
                            <CheckBox IsChecked="{Binding IsMarked}"
                                      VerticalAlignment="Center" Margin="0,0,4,0"
                                      Visibility="{Binding DataContext.IsSelectMode,
                                          RelativeSource={RelativeSource AncestorType=TreeView},
                                          Converter={StaticResource BoolToVisConverter}}"/>
                            <CheckBox IsChecked="{Binding FolderEnabled}"
                                      VerticalAlignment="Center" Margin="0,0,4,0"
                                      ToolTip="Enable/disable all triggers in this folder"/>
                            <TextBlock Text="{Binding FolderName}" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsRenaming,
                                           Converter={StaticResource InverseBoolToVisConverter}}"
                                       MouseLeftButtonDown="FolderName_MouseLeftButtonDown"/>
                            <TextBox Text="{Binding FolderName, UpdateSourceTrigger=PropertyChanged}"
                                     MinWidth="90" VerticalAlignment="Center"
                                     Visibility="{Binding IsRenaming,
                                         Converter={StaticResource BoolToVisConverter}}"
                                     LostFocus="FolderNameBox_LostFocus"
                                     KeyDown="FolderNameBox_KeyDown"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>

                    <!-- Trigger template (leaf) -->
                    <DataTemplate DataType="{x:Type vm:TriggerNode}">
                        <StackPanel Orientation="Horizontal">
                            <!-- Mark checkbox (select mode only) -->
                            <CheckBox IsChecked="{Binding IsMarked}"
                                      VerticalAlignment="Center" Margin="0,0,4,0"
                                      Visibility="{Binding DataContext.IsSelectMode,
                                          RelativeSource={RelativeSource AncestorType=TreeView},
                                          Converter={StaticResource BoolToVisConverter}}"/>
                            <CheckBox IsChecked="{Binding IsEnabled}"
                                      VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </TreeView.Resources>
            </TreeView>
        </Grid>

        <!-- Right: editor -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16" IsEnabled="{Binding HasSelection}">

                <!-- Basic info -->
                <TextBlock Text="Trigger" Foreground="{StaticResource TextSecondaryBrush}"
                           FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Name:" VerticalAlignment="Center"
                               Foreground="{StaticResource TextDimBrush}"/>
                    <TextBox Grid.Column="1" Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Enabled:" VerticalAlignment="Center"
                               Foreground="{StaticResource TextDimBrush}"/>
                    <CheckBox Grid.Column="1" IsChecked="{Binding EditEnabled}" VerticalAlignment="Center"/>
                </Grid>



                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Cooldown:" VerticalAlignment="Center"
                               Foreground="{StaticResource TextDimBrush}"/>
                    <TextBox Grid.Column="1" Text="{Binding EditCooldownSec, UpdateSourceTrigger=LostFocus}"/>
                    <TextBlock Grid.Column="2" Text=" sec" VerticalAlignment="Center"
                               Foreground="{StaticResource TextDimBrush}" Margin="4,0,0,0"/>
                </Grid>

                <!-- Capture phrases -->
                <TextBlock Text="Match Phrases" Foreground="{StaticResource TextSecondaryBrush}"
                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBlock Text="Line must contain any of these (text or regex). Regex groups captured as {S0}, {S1}, {GroupName}."
                           TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextDimBrush}"
                           Margin="0,0,0,8"/>

                <DataGrid ItemsSource="{Binding EditPhrases}"
                          SelectedItem="{Binding SelectedPhrase}"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          MaxHeight="160" Margin="0,0,0,6">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Pattern" Binding="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridCheckBoxColumn Header="Regex" Binding="{Binding UseRegex}" Width="56"/>
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="+ Phrase" Command="{Binding AddPhraseCommand}" Margin="0,0,6,0"/>
                    <Button Content="Remove" Command="{Binding RemovePhraseCommand}"/>
                </StackPanel>

                <!-- Regex snippets -->
                <Expander Header="Regex Snippets  (click to copy)" Margin="0,0,0,16"
                          Foreground="{StaticResource TextDimBrush}" FontSize="11">
                    <Border Background="{StaticResource BgMidBrush}" CornerRadius="4"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Padding="8,6" Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="Paste a snippet into the Pattern field. Enable 'Regex' on the phrase."
                                       TextWrapping="Wrap" FontSize="11"
                                       Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Capture tokens" FontWeight="SemiBold"
                                               FontSize="11" Margin="0,0,0,4"/>
                                    <ItemsControl ItemsSource="{Binding SnippetTokens}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="0,2">
                                                    <Button DockPanel.Dock="Left"
                                                            Content="{Binding Token}"
                                                            Command="{Binding DataContext.CopySnippetCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding Token}"
                                                            FontFamily="Consolas" FontSize="11"
                                                            Padding="4,2" Margin="0,0,6,0"
                                                            ToolTip="Click to copy"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="11" VerticalAlignment="Center"
                                                               Foreground="{StaticResource TextDimBrush}"
                                                               TextWrapping="Wrap"/>
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Full-phrase templates" FontWeight="SemiBold"
                                               FontSize="11" Margin="0,0,0,4"/>
                                    <ItemsControl ItemsSource="{Binding SnippetTemplates}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,2">
                                                    <Button Content="{Binding Label}"
                                                            Command="{Binding DataContext.CopySnippetCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding Token}"
                                                            FontSize="11" Padding="4,2"
                                                            HorizontalContentAlignment="Left"
                                                            ToolTip="{Binding Token}"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="10" Margin="4,0,0,0"
                                                               Foreground="{StaticResource TextDimBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- Actions -->
                <TextBlock Text="Actions" Foreground="{StaticResource TextSecondaryBrush}"
                           FontWeight="SemiBold" Margin="0,0,0,6"/>

                <DataGrid ItemsSource="{Binding EditActions}"
                          SelectedItem="{Binding SelectedAction}"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          MaxHeight="200" Margin="0,0,0,6">
                    <DataGrid.Columns>
                        <DataGridComboBoxColumn Header="Type" Width="100"
                            SelectedItemBinding="{Binding ActionType, UpdateSourceTrigger=PropertyChanged}"
                            ItemsSource="{StaticResource ActionTypeValues}"/>
                        <DataGridTextColumn Header="Text / Path" Binding="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTextColumn Header="Duration (s)" Binding="{Binding DurationSec, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Button Content="+ Action" Command="{Binding AddActionCommand}" Margin="0,0,6,0"/>
                    <Button Content="Remove" Command="{Binding RemoveActionCommand}"/>
                </StackPanel>

                <!-- Action detail -->
                <Border Background="{StaticResource BgMidBrush}" CornerRadius="4"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="10,8" Margin="0,0,0,16"
                        Visibility="{Binding SelectedAction, Converter={StaticResource NotNullToVisConverter}}">
                    <StackPanel>
                        <TextBlock Text="Action detail" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Text:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}"/>
                            <TextBox Grid.Column="1" Text="{Binding SelectedAction.Text, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Use {S0},{S1} for regex groups, {C} for character name, {L} for full line"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Duration:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}"/>
                            <TextBox Grid.Column="1" Text="{Binding SelectedAction.DurationSec, UpdateSourceTrigger=LostFocus}"/>
                            <TextBlock Grid.Column="2" Text=" sec" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" Margin="4,0"/>
                        </Grid>
                        <!-- Bar color (Timer actions only) -->
                        <Grid Margin="0,0,0,6">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedAction.ActionType}"
                                                     Value="{x:Static models:TriggerActionType.Timer}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="28"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Bar color:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding EditActionTimerBarColor, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="#AARRGGBB hex — color of the timer progress bar. Empty uses the default blue."/>
                            <Border Grid.Column="2" Margin="4,0,0,0" CornerRadius="3"
                                    BorderBrush="#40FFFFFF" BorderThickness="1"
                                    Background="{Binding EditActionTimerBarColor,
                                                 Converter={StaticResource StringToBrushConverter}}"/>
                        </Grid>
                        <!-- Text color -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Text color:" VerticalAlignment="Top"
                                       Margin="0,4,0,0" Foreground="{StaticResource TextDimBrush}"/>
                            <StackPanel Grid.Column="1">
                                <ctrl:ColorWheelPicker
                                    SelectedHex="{Binding EditActionColor, Mode=TwoWay}"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding EditActionColor, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="#AARRGGBB hex"/>
                                    <Border Grid.Column="1" Margin="4,0,0,0" CornerRadius="3"
                                            BorderBrush="#40FFFFFF" BorderThickness="1"
                                            Background="{Binding EditActionColor,
                                                         Converter={StaticResource StringToBrushConverter}}"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                        <!-- Font -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Font:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding EditActionFontSize, UpdateSourceTrigger=LostFocus}"/>
                            <TextBlock Grid.Column="2" Text=" pt" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" Margin="4,0,12,0"/>
                            <CheckBox Grid.Column="3" Content="Bold"
                                      IsChecked="{Binding EditActionBold}" VerticalAlignment="Center"/>
                        </Grid>
                        <!-- Overlay (DisplayText / Timer only) -->
                        <Grid Margin="0,0,0,6">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedAction.ActionType}"
                                                     Value="{x:Static models:TriggerActionType.DisplayText}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedAction.ActionType}"
                                                     Value="{x:Static models:TriggerActionType.Timer}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Overlay:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding DataContext.AvailableOverlays,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedValue="{Binding SelectedAction.OverlayId,
                                                      UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Id">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                        <!-- Audio -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Audio file:" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}"/>
                            <TextBox Grid.Column="1" x:Name="AudioPathBox"
                                     Text="{Binding SelectedAction.AudioPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="Browse…" Margin="6,0,0,0"
                                    Click="BrowseAudio_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Save -->
                <Button Content="Save Trigger" Command="{Binding SaveTriggerCommand}"
                        HorizontalAlignment="Left" Padding="16,6"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
